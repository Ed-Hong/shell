# Util Functions: General
back() {
    if [ $# = 1 ]; # if 1 arg
    then
        cd +"$1"
    else
        cd -
    fi
}

find() {
    if [ $# = 1 ]; # if 1 arg
    then
        command find . -iname "*$@*"
    else
        command find "$@"
    fi
}

greps() {
    command find . -type f -maxdepth 1 -exec grep --color "$@" {} +
}

grepr() {
    if [ $# = 0 ]; # if 0 arg
    then
        echo "no search query"
    elif [ $# = 1 ]; # if 1 arg
    then
        greps "$@"
    elif [ $# = 2 ]; # if 2 arg
    then
        command find . -type f -maxdepth "$2" -exec grep --color "$1" {} +
    else
        echo "running: grep -r --color \""$@"\""
        grep -r --color "$@"
        echo "done: grep -r --color \""$@"\""
    fi
}

dif() {
    if [ $# = 2 ]; # if 2 arg
    then
        #comm -3 <(sort "$1") <(sort "$2")
        git diff --no-index "$1" "$2"
    else
        echo "need 2 arg: old, new"
    fi
}

