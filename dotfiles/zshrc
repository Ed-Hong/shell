# Util Functions: Git
gcm() {
    git commit -m "$1"
}

gcmp() {
    git commit -m "$1"
    git push
}

gacm() {
    git add .
    git commit -m "$1"
}

gacmp() {
    git add .
    git commit -m "$1"
    git push
}

gsh() {
    if [ -n "$1" ]
    then
        git show "$1"
    else
        git show head
    fi
}

gsq() {
    if [ $# = 1 ]; # if 1 arg
    then
        git reset --soft HEAD~"$1" &&
        git commit --edit -m"$(git log --format=%B --reverse HEAD..HEAD@{1})"
    else
        echo "need 1 arg: number of commits to squash"
    fi
}

gstpk() {
    if [ -n "$1" ]
    then
        git stash show -p stash@{"$1"}
    else
        git stash show -p stash@{0}
    fi
}

gbr() {
    git branch | grep -v "main" | xargs git branch -D
}

