alias fk='fuck'
alias so='stackoverflow'

alias g='git'
alias gs='git status'
alias gdf='git diff'
alias gdfc='git diff --cached'
alias ga='git add .'
alias gap='git add . -p'
alias gdsc='git checkout -- .'
alias grst='git reset HEAD'
alias gb='git branch'
alias gbd='git branch -D $(git branch | egrep -v "main")'
alias gbl='git branch -l'
alias gbla='git branch -la'
alias gco='git checkout'
alias gcom='git checkout ???'
alias gf='git fetch'
alias gpsh='git push'
alias gpul='git pull'
alias glg='git log'
alias glog='git log --oneline --decorate --graph'
alias gst='git stash'
alias gstl='git stash list'
alias gstp='git stash pop'
alias gsta='git stash apply'
alias grp='git remote prune origin'

alias clr='clear'
alias ls='colorls --sd'
alias lsg='colorls --sd --gs'

gcm() {
    git commit -m "$1"
}

gcmp() {
    git commit -m "$1"
    git push
}

gacm() {
    git add .
    git commit -m "$1"
}

gacmp() {
    git add .
    git commit -m "$1"
    git push
}

gsh() {
    if [ -n "$1" ] 
    then
        git show "$1"
    else
        git show head
    fi
}

gpeek() {
    if [ -n "$1" ] 
    then
        git stash show -p stash@{"$1"}
    else
        git stash show -p stash@{0}
    fi
}

gbr() {
    git branch | grep -v "master" | xargs git branch -D
}

lst() {
    if [ -n "$1" ] 
    then
        colorls --sd --tree="$1"
    else
        colorls --sd --tree=2
    fi
}

lstg() {
    if [ -n "$1" ] 
    then
        colorls --sd --tree="$1" --gs
    else
        colorls --sd --tree=2 --gs
    fi
}

function find() {
    if [ $# = 1 ];
    then
        command find . -iname "*$@*"
    else
        command find "$@"
    fi
}

eval $(thefuck --alias)
